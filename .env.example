# Run `npm run bootstrap:env` to generate ignored local values in `.env.local`.
PERCEPTIONLAB_ENV=local
PERCEPTIONLAB_PROJECT_ROOT=/home/jerem/vision-lab
PERCEPTIONLAB_DATA_ROOT=/home/jerem/vision-lab/datasets
PERCEPTIONLAB_SEED_DATASET_ROOT=/home/jerem/vision-lab/datasets/seed
PERCEPTIONLAB_STORAGE_ROOT=/home/jerem/vision-lab/.perceptionlab/storage
PERCEPTIONLAB_ARTIFACT_ROOT=/home/jerem/vision-lab/.perceptionlab/artifacts
PERCEPTIONLAB_TMP_ROOT=/home/jerem/vision-lab/.perceptionlab/tmp
PERCEPTIONLAB_DATABASE_URL=postgres://perceptionlab:perceptionlab@localhost:5432/perceptionlab
PERCEPTIONLAB_QUEUE_URL=postgres://perceptionlab:perceptionlab@localhost:5432/perceptionlab
PERCEPTIONLAB_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
PERCEPTIONLAB_OBJECT_STORAGE_BUCKET=perceptionlab
