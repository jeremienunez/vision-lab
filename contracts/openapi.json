{
  "openapi": "3.1.0",
  "info": {
    "title": "PerceptionLab API",
    "version": "0.1.0",
    "description": "HTTP contract for PerceptionLab dataset, annotation, training, model, inference, export, and overlay workflows."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080",
      "description": "Local development API"
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Datasets" },
    { "name": "Samples" },
    { "name": "Annotations" },
    { "name": "Dataset Versions" },
    { "name": "Training Jobs" },
    { "name": "Models" },
    { "name": "Inference" },
    { "name": "Exports" },
    { "name": "Overlays" }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "tags": ["Health"],
        "summary": "Check API readiness.",
        "responses": {
          "200": {
            "description": "API health status.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/datasets": {
      "post": {
        "operationId": "createDataset",
        "tags": ["Datasets"],
        "summary": "Create a dataset.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateDatasetRequest" }
            }
          }
        },
        "responses": {
          "201": { "$ref": "#/components/responses/DatasetCreated" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      },
      "get": {
        "operationId": "listDatasets",
        "tags": ["Datasets"],
        "summary": "List datasets.",
        "responses": {
          "200": {
            "description": "Dataset list.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListDatasetsResponse" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/datasets/{dataset_id}/stats": {
      "get": {
        "operationId": "getDatasetStats",
        "tags": ["Datasets"],
        "summary": "Read dataset sample and annotation stats.",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "responses": {
          "200": {
            "description": "Dataset statistics.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetStatsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/datasets/{dataset_id}/samples": {
      "post": {
        "operationId": "uploadSample",
        "tags": ["Samples"],
        "summary": "Upload an image sample.",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "width", "height"],
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "width": { "type": "integer", "minimum": 1 },
                  "height": { "type": "integer", "minimum": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Uploaded sample.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SampleResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/samples/{sample_id}/annotations": {
      "post": {
        "operationId": "addAnnotation",
        "tags": ["Annotations"],
        "summary": "Add a bounding-box annotation.",
        "parameters": [{ "$ref": "#/components/parameters/SampleId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddAnnotationRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created annotation.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AnnotationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      },
      "get": {
        "operationId": "listSampleAnnotations",
        "tags": ["Annotations"],
        "summary": "List sample annotations.",
        "parameters": [{ "$ref": "#/components/parameters/SampleId" }],
        "responses": {
          "200": {
            "description": "Sample annotations.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListAnnotationsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/datasets/{dataset_id}/versions": {
      "post": {
        "operationId": "createDatasetVersion",
        "tags": ["Dataset Versions"],
        "summary": "Create an immutable dataset version.",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateDatasetVersionRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created dataset version.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetVersionResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/training-jobs": {
      "post": {
        "operationId": "createTrainingJob",
        "tags": ["Training Jobs"],
        "summary": "Create an async training job.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTrainingJobRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created training job.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TrainingJobResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/training-jobs/{training_job_id}/metrics": {
      "get": {
        "operationId": "listTrainingMetrics",
        "tags": ["Training Jobs"],
        "summary": "Read training metrics.",
        "parameters": [{ "$ref": "#/components/parameters/TrainingJobId" }],
        "responses": {
          "200": {
            "description": "Training metrics.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListTrainingMetricsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/training-jobs/{training_job_id}/metrics/by-class": {
      "get": {
        "operationId": "listTrainingClassMetrics",
        "tags": ["Training Jobs"],
        "summary": "Read class-level training metrics.",
        "parameters": [{ "$ref": "#/components/parameters/TrainingJobId" }],
        "responses": {
          "200": {
            "description": "Class-level training metrics.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListTrainingClassMetricsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/training-jobs/{training_job_id}/status": {
      "patch": {
        "operationId": "transitionTrainingJobStatus",
        "tags": ["Training Jobs"],
        "summary": "Transition a training job status.",
        "parameters": [{ "$ref": "#/components/parameters/TrainingJobId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TransitionTrainingJobRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated training job.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TrainingJobResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/models": {
      "get": {
        "operationId": "listModels",
        "tags": ["Models"],
        "summary": "List registered models.",
        "responses": {
          "200": {
            "description": "Model list.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListModelsResponse" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      },
      "post": {
        "operationId": "registerModel",
        "tags": ["Models"],
        "summary": "Register a model from a succeeded training job.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterModelRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered model.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/models/compare": {
      "post": {
        "operationId": "compareModels",
        "tags": ["Models"],
        "summary": "Compare registered models by a shared numeric metric.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompareModelsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Model comparison.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelComparisonResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/models/{model_id}": {
      "get": {
        "operationId": "getModel",
        "tags": ["Models"],
        "summary": "Read model detail.",
        "parameters": [{ "$ref": "#/components/parameters/ModelId" }],
        "responses": {
          "200": {
            "description": "Model detail.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/models/{model_id}/promote": {
      "post": {
        "operationId": "promoteModel",
        "tags": ["Models"],
        "summary": "Promote a model and demote competing promoted models.",
        "parameters": [{ "$ref": "#/components/parameters/ModelId" }],
        "responses": {
          "200": {
            "description": "Promoted model.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/models/{model_id}/infer": {
      "post": {
        "operationId": "runInference",
        "tags": ["Inference"],
        "summary": "Run inference on an image.",
        "parameters": [{ "$ref": "#/components/parameters/ModelId" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": { "type": "string", "format": "binary" },
                  "confidence_threshold": {
                    "type": "number",
                    "format": "float",
                    "default": 0.25
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inference result.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/InferenceResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaTypeError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/models/{model_id}/exports": {
      "post": {
        "operationId": "exportModel",
        "tags": ["Exports"],
        "summary": "Create a model export.",
        "parameters": [{ "$ref": "#/components/parameters/ModelId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateModelExportRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created model export.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelExportResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      },
      "get": {
        "operationId": "listModelExports",
        "tags": ["Exports"],
        "summary": "List model exports.",
        "parameters": [{ "$ref": "#/components/parameters/ModelId" }],
        "responses": {
          "200": {
            "description": "Model exports.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListModelExportsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/datasets/{dataset_id}/import/yolo": {
      "post": {
        "operationId": "importYoloAnnotations",
        "tags": ["Annotations"],
        "summary": "Import YOLO annotations.",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/YoloAnnotationImportRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "YOLO import result.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/YoloAnnotationImportResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/datasets/{dataset_id}/export/yolo": {
      "get": {
        "operationId": "exportYoloAnnotations",
        "tags": ["Annotations"],
        "summary": "Export annotations in YOLO format.",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "responses": {
          "200": {
            "description": "YOLO annotation export.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/YoloAnnotationExportResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    },
    "/inference-runs/{run_id}/overlay": {
      "post": {
        "operationId": "generateOverlay",
        "tags": ["Overlays"],
        "summary": "Generate an SVG overlay from stored inference detections.",
        "parameters": [{ "$ref": "#/components/parameters/InferenceRunId" }],
        "responses": {
          "201": {
            "description": "Generated overlay artifact.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OverlayResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "$ref": "#/components/responses/RepositoryError" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "DatasetId": {
        "name": "dataset_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "SampleId": {
        "name": "sample_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "TrainingJobId": {
        "name": "training_job_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "ModelId": {
        "name": "model_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "InferenceRunId": {
        "name": "run_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "responses": {
      "DatasetCreated": {
        "description": "Created dataset.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/DatasetResponse" }
          }
        }
      },
      "ValidationError": {
        "description": "Validation error.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFoundError": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "UnsupportedMediaTypeError": {
        "description": "Unsupported media type.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "RepositoryError": {
        "description": "Repository or adapter failure.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status", "dependencies"],
        "additionalProperties": false,
        "properties": {
          "status": { "type": "string", "example": "healthy" },
          "dependencies": { "$ref": "#/components/schemas/HealthDependencies" }
        }
      },
      "HealthDependencies": {
        "type": "object",
        "required": ["database", "storage", "queue"],
        "additionalProperties": false,
        "properties": {
          "database": { "type": "string" },
          "storage": { "type": "string" },
          "queue": { "type": "string" }
        }
      },
      "CreateDatasetRequest": {
        "type": "object",
        "required": ["name", "task_type", "classes"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "task_type": { "type": "string", "enum": ["object_detection"] },
          "classes": { "type": "array", "items": { "type": "string" } }
        }
      },
      "DatasetResponse": {
        "type": "object",
        "required": ["id", "name", "description", "task_type", "classes", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "task_type": { "type": "string" },
          "classes": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string" }
        }
      },
      "ListDatasetsResponse": {
        "type": "object",
        "required": ["datasets"],
        "additionalProperties": false,
        "properties": {
          "datasets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DatasetResponse" }
          }
        }
      },
      "SampleResponse": {
        "type": "object",
        "required": [
          "id",
          "dataset_id",
          "storage_uri",
          "filename",
          "mime_type",
          "width",
          "height",
          "size_bytes",
          "checksum",
          "source"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "dataset_id": { "type": "string" },
          "storage_uri": { "type": "string" },
          "filename": { "type": "string" },
          "mime_type": { "type": "string" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "checksum": { "type": "string" },
          "source": { "type": "string" }
        }
      },
      "AddAnnotationRequest": {
        "type": "object",
        "required": ["class_name", "bbox"],
        "additionalProperties": false,
        "properties": {
          "class_name": { "type": "string" },
          "bbox": { "$ref": "#/components/schemas/BboxRequest" },
          "confidence": { "type": ["number", "null"], "format": "float" }
        }
      },
      "BboxRequest": {
        "type": "object",
        "required": ["x", "y", "width", "height"],
        "additionalProperties": false,
        "properties": {
          "x": { "type": "number", "format": "float", "minimum": 0, "maximum": 1 },
          "y": { "type": "number", "format": "float", "minimum": 0, "maximum": 1 },
          "width": { "type": "number", "format": "float", "minimum": 0, "maximum": 1 },
          "height": { "type": "number", "format": "float", "minimum": 0, "maximum": 1 }
        }
      },
      "BboxResponse": {
        "type": "object",
        "required": ["x", "y", "width", "height"],
        "additionalProperties": false,
        "properties": {
          "x": { "type": "number", "format": "float" },
          "y": { "type": "number", "format": "float" },
          "width": { "type": "number", "format": "float" },
          "height": { "type": "number", "format": "float" }
        }
      },
      "AnnotationResponse": {
        "type": "object",
        "required": [
          "id",
          "sample_id",
          "dataset_id",
          "class_name",
          "class_id",
          "bbox",
          "format",
          "confidence",
          "source"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "sample_id": { "type": "string" },
          "dataset_id": { "type": "string" },
          "class_name": { "type": "string" },
          "class_id": { "type": "integer", "minimum": 0 },
          "bbox": { "$ref": "#/components/schemas/BboxResponse" },
          "format": { "type": "string" },
